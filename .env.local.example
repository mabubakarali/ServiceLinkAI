# ServiceLink AI — Environment Configuration
# Copy this file to .env.local and fill in your API key

# Get your Gemini API Key from: https://aistudio.google.com/
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Note: The system includes a full heuristic fallback engine.
# If no key is provided, the platform will use regex-based intent parsing.
# For full LLM reasoning traces, a valid key is required.
